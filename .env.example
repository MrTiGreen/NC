# =========================
# Database
# =========================
# Local Docker PostgreSQL example:
DATABASE_URL="postgresql://chat:chat@localhost:5432/chat?schema=public"

# =========================
# Telegram Bot
# =========================
# Production: put real bot token in Render/Railway env, never commit it.
BOT_TOKEN=""

# =========================
# Auth / Security
# =========================
# Production: generate a new strong secret.
# Example command:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-secret-before-production"

# Production should be false.
DEV_TELEGRAM_AUTH="true"

# Max age for Telegram initData auth in seconds.
TELEGRAM_AUTH_MAX_AGE_SECONDS="86400"

# =========================
# Server
# =========================
PORT="4000"

# Local frontend origin:
CLIENT_ORIGIN="http://localhost:5173"

# Production example:
# CLIENT_ORIGIN="https://your-frontend-domain.vercel.app"

# =========================
# Dev Telegram User
# Used only when DEV_TELEGRAM_AUTH=true
# =========================
DEV_TELEGRAM_ID="100000001"
DEV_TELEGRAM_USERNAME="dev_user"
DEV_TELEGRAM_FIRST_NAME="Dev"
DEV_TELEGRAM_LAST_NAME="User"
DEV_TELEGRAM_AVATAR_URL=""

# =========================
# Admins
# Telegram numeric user IDs, comma-separated.
# Example: ADMIN_TELEGRAM_IDS="123456789,987654321"
# =========================
ADMIN_TELEGRAM_IDS="100000001"

# =========================
# Chat limits / moderation
# =========================
MESSAGE_RATE_LIMIT_PER_MINUTE="30"
CHAT_MODERATION_ENABLED="true"
CHAT_MODERATION_RECURRENCE_WINDOW_HOURS="24"